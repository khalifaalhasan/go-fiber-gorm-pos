    "definitions": {
        "auth.LoginRequest": {
            "type": "object",
            "required": [
                "password",
                "username"
            ],
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "auth.RegisterRequest": {
            "type": "object",
            "required": [
                "name",
                "password",
                "username"
            ],
            "properties": {
                "name": {
                    "description": "StoreName dan Subdomain DIHAPUS karena Single-Tenant",
                    "type": "string",
                    "minLength": 3
                },
                "password": {
                    "type": "string",
                    "minLength": 6
                },
                "username": {
                    "type": "string",
                    "minLength": 4
                }
            }
        },
        "category.CreateCategoryRequest": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 3
                }
            }
        },
        "inventory.AdjustStockRequest": {
            "type": "object",
            "required": [
                "notes",
                "product_id",
                "qty_change"
            ],
            "properties": {
                "notes": {
                    "type": "string"
                },
                "product_id": {
                    "type": "string"
                },
                "qty_change": {
                    "type": "integer"
                }
            }
        },
        "order.CheckoutItemInput": {
            "type": "object",
            "required": [
                "product_id",
                "qty"
            ],
            "properties": {
                "notes": {
                    "type": "string"
                },
                "product_id": {
                    "type": "string"
                },
                "qty": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "order.CheckoutRequest": {
            "type": "object",
            "required": [
                "items",
                "order_source"
            ],
            "properties": {
                "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/definitions/order.CheckoutItemInput"
                    }
                },
                "order_source": {
                    "type": "string",
                    "enum": [
                        "CASHIER",
                        "E_MENU"
                    ]
                },
                "table_number": {
                    "type": "string"
                },
                "voucher_code": {
                    "type": "string"
                }
            }
        },
        "payment.InitiatePaymentRequest": {
            "type": "object",
            "required": [
                "order_id",
                "payment_method"
            ],
            "properties": {
                "order_id": {
                    "type": "string"
                },
                "payment_method": {
                    "type": "string",
                    "enum": [
                        "CASH",
                        "QRIS",
                        "TRANSFER"
                    ]
                }
            }
        },
        "payment.WebhookPayload": {
            "type": "object",
            "properties": {
                "fraud_status": {
                    "type": "string"
                },
                "gross_amount": {
                    "type": "string"
                },
                "order_id": {
